APP_NAME=Covercraft
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_PORT=80

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=covercraft
DB_USERNAME=covercraft
DB_PASSWORD=secret

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

MAIL_MAILER=log

# GitHub App credentials
GITHUB_APP_ID=
GITHUB_APP_WEBHOOK_SECRET=

# GITHUB_APP_PRIVATE_KEY: PEM keys contain literal newlines which break .env parsing.
# Option A (recommended): Base64-encode the PEM key and decode it in your app.
#   Encode: base64 -w 0 < your-key.pem
#   Then set: GITHUB_APP_PRIVATE_KEY_BASE64=<encoded-value>
# Option B: Mount the key file as a Docker secret and reference it by path.
#   Then set: GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github_private_key
GITHUB_APP_PRIVATE_KEY=

COVERAGE_STORAGE_DISK=local
